@* Views/Projects/Index.cshtml *@
@using BathandwaPortfolioWebsite.Models

@{
    ViewData["Title"] = "Projects"; 
    var featured = ViewBag.featured as List<Project>;
}

    <h1>Projects</h1>


    @if (featured.Count > 0 && featured.Count != 0)
    {
        foreach (var project in featured)
        {
            <h3>@project.Title</h3>
            <p>
                @if (project.IconImageUrl != null)
                {
                    <img src="@project.IconImageUrl" class="project-icon"/>
                }
                <br/>
                @project.Tagline
            </p>
            <p>
                Technologies used: 
                @foreach (var tech in project.TechStack)
                {
                    <span class="techBadge"><strong>@tech</strong></span>
                } 
            </p>
            @if (project.LiveUrl != null)
            {
                <p>
                    See it live here: <a href="@project.LiveUrl" target="_blank">@project.LiveUrl</a> 
                </p>
            }
            @if (project.ProjectlinkUrl != null)
            {
                <p>
                    Github: <a href="@project.ProjectlinkUrl" target="_blank">@project.ProjectlinkUrl</a>
                </p>
            }
            <p>
                See more details about the project and my reflections throughout the project lifecycle:
                <a asp-controller="Projects" asp-action="Detail" asp-route-slug=@project.Slug>Details</a>
            </p>
        
        }
    }
